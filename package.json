{
  "name": "reunion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iMessage-first group travel planning agent (coordination-memory).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sidecar:build": "cd sidecar && swift build -c release",
    "sidecar:smoke": "cd sidecar && swift build -c release >/dev/null && printf '%s\\n' '{\"window\":\"we should do a trip to Lisbon in September\"}' '{\"window\":\"did you watch the game last night\"}' | ./.build/release/intent-sidecar",
    "dev": "tsx src/index.ts",
    "start": "npm run sidecar:build && tsx src/index.ts",
    "demo": "tsx src/demo.ts",
    "db:provision": "tsx --env-file=.env src/state/provision.ts",
    "db:smoke": "tsx --env-file=.env src/state/smoke.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@butterbase/sdk": "^2.4.0",
    "@photon-ai/imessage-kit": "^3.0.0",
    "rocketride": "^1.2.0",
    "spectrum-ts": "^1.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
