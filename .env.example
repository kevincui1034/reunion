# Reunion — environment template. Copy to .env and fill in as integrations land.
# Nothing here is required to run `npm run demo` (the scaffold uses in-memory stubs).

# --- Messaging: Spectrum (iMessage local mode) — Ethan ---
# SPECTRUM_LOCAL=true            # reads chat.db on the Mac, no network

# --- RocketRide pipeline — Pablo / Jossue ---
# The pipeline runs on the heuristic stub until these are set AND USE_STUBS=false.
# The extension command "RocketRide: Setup API Key & URL" can write URI + APIKEY here.
# ROCKETRIDE_URI=ws://127.0.0.1:36583        # LOCAL engine — DYNAMIC port, changes each restart (re-check: ss -tlnp | grep engine). Not 5565.
# ROCKETRIDE_APIKEY=API                       # any non-empty value: the LOCAL engine only checks a key is present, not its value
# ROCKETRIDE_PIPELINE=pipelines/extract-trip-signal.pipe   # the committed extraction pipeline (see pipelines/README.md)
# The committed pipeline's llm_openai_api node runs on Nebius — these are referenced as ${...} inside the .pipe:
# ROCKETRIDE_NEBIUS_KEY=                       # Nebius API key (api.studio.nebius.com)
# ROCKETRIDE_NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
# ROCKETRIDE_NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
# ROCKETRIDE_TIMEOUT_MS=60000                 # degrade to the heuristic if the engine doesn't answer in time (agents are slow)
# ROCKETRIDE_ITINERARY_PIPELINE=pipelines/generate-itinerary.pipe   # itinerary generation pipe (defaults here); degrades to a template

# --- Calendar availability: Kevin's endpoint — Jossue ↔ Kevin ---
# Availability runs on the in-process interval stub until BOTH are set AND USE_STUBS=false.
# CALENDAR_BASE_URL=https://reunion-calendar.vercel.app
# CALENDAR_INTERNAL_KEY=                       # == Kevin's INTERNAL_API_KEY (shared over a side channel)

# --- XTrace durable memory — shared ---
# Real XTrace memory (@xtraceai/memory) is used when these are set AND USE_STUBS=false.
# Verify: `npm run xtrace:smoke`
# XTRACE_API_KEY=xtk_xxxxxxxx
# XTRACE_ORG_ID=

# --- Butterbase backend state — shared ---
# Real Butterbase StateStore is used when these are set AND USE_STUBS=false.
# Provision tables once: `npm run db:provision`  ·  verify: `npm run db:smoke`
# BUTTERBASE_APP_ID=app_xxxxxxxx
# BUTTERBASE_API_KEY=bb_sk_xxxxxxxx
# BUTTERBASE_BASE_URL=https://api.butterbase.ai/v1/app_xxxxxxxx

# --- Feature flags ---
USE_STUBS=true                   # in-memory XTrace/Butterbase/channel; flip per-layer as SDKs land
