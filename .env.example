# Copy to .env and fill in the secret. The real .env is gitignored.
#
#   cp .env.example .env

# Shared Butterbase app (the app id is not secret; the API key is).
BUTTERBASE_APP_ID=app_4lls3kxgops9
BUTTERBASE_BASE_URL=https://api.butterbase.ai/v1/app_4lls3kxgops9
# SECRET — get the real bb_sk_... key from the team. Leave blank to run the gate
# in dry-run mode (classifies + prints, logs instead of writing rows).
BUTTERBASE_API_KEY=

# Comma-separated chat display names to watch (default: Dev). Other chats ignored.
REUNION_CHATS=Dev
# Minimum confidence (0..1) before a YES is forwarded to the backend.
REUNION_MIN_CONFIDENCE=0.5
# Display name for messages sent from this Mac's own account.
REUNION_OWNER_NAME=Pablo
