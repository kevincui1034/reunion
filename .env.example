# Reunion — environment template. Copy to .env and fill in as integrations land.
# Nothing here is required to run `npm run demo` (the scaffold uses in-memory stubs).

# --- Messaging: Spectrum (iMessage local mode) — Ethan ---
# SPECTRUM_LOCAL=true            # reads chat.db on the Mac, no network

# --- RocketRide pipeline — Pablo / Jossue ---
# The pipeline runs on the heuristic stub until you set these AND USE_STUBS=false.
# ROCKETRIDE_URI=ws://localhost:5565        # local engine (VS Code extension / Docker). From WSL, use ws://172.24.0.1:5565 if the engine runs on Windows.
# ROCKETRIDE_APIKEY=                         # auth token from the RocketRide Connection Manager (ROCKETRIDE_AUTH also accepted)
# ROCKETRIDE_PIPELINE=./pipelines/extract-trip-signal.json   # exported pipeline that emits a TripSignal (see pipelines/README.md)

# --- XTrace durable memory — shared ---
# XTRACE_API_KEY=

# --- Butterbase backend state + model gateway — shared ---
# BUTTERBASE_API_KEY=
# BUTTERBASE_PROJECT=

# --- Feature flags ---
USE_STUBS=true                   # in-memory XTrace/Butterbase/channel; flip per-layer as SDKs land
