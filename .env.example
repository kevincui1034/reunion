# --- App ---
# Public URL the OAuth callback redirects to. Locally use http://localhost:3000.
# In Vercel, set this to the deployed URL.
APP_URL=http://localhost:3000

# --- Google Calendar OAuth ---
# Create an OAuth client (type: Web application) at
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${APP_URL}/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# --- Signed state ---
# 32+ random bytes (hex). Used to HMAC-sign the {tripId, participantId, exp} state token.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STATE_SIGNING_KEY=

# --- Internal API auth ---
# Shared secret required in the x-internal-key header on POST /api/availability.
INTERNAL_API_KEY=

# --- Test mode allowlist ---
# Google OAuth app is in Testing mode. Only these emails can complete consent.
# CSV, e.g. "alice@example.com, bob@example.com" — quote when it contains spaces.
ALLOWED_TEST_EMAILS=

# --- Butterbase (storage) ---
# From your https://butterbase.ai/ app dashboard. App ID looks like `app_<hex>`.
BUTTERBASE_APP_ID=
BUTTERBASE_API_KEY=
BUTTERBASE_BASE_URL=https://api.butterbase.ai
